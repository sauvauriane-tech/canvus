{
  "name": "canvus-ai",
  "version": "0.1.0",
  "description": "AI design assistant for Canvus — ops-based, Mistral-powered",
  "type": "module",
  "bin": {
    "canvus-ai": "./dist/cli/canvus-ai.js"
  },
  "scripts": {
    "dev":       "ts-node-esm backend/express.ts",
    "build":     "tsc && tsc -p tsconfig.worker.json --noEmit",
    "test":      "jest --passWithNoTests",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "deploy":    "wrangler deploy src/worker.ts"
  },
  "dependencies": {
    "ajv":         "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cors":        "^2.8.5",
    "dotenv":      "^16.4.5",
    "express":     "^4.21.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/cors":               "^2.8.17",
    "@types/express":            "^5.0.0",
    "@types/jest":               "^29.5.14",
    "@types/node":               "^22.7.5",
    "jest":                      "^29.7.0",
    "ts-jest":                   "^29.2.5",
    "ts-node":                   "^10.9.2",
    "typescript":                "^5.6.3",
    "wrangler":                  "^3.80.0"
  },
  "jest": {
    "preset":      "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
